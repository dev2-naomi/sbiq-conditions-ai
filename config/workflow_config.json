{
  "workflow_name": "conditions-evaluator",
  "description": "Agentic underwriting condition evaluator. Given loan conditions and uploaded evidence documents, determine whether each condition is Fulfilled, Partially Fulfilled, Unfulfilled, or Needs Review.",
  "general_tools": ["write_todo", "get_workflow_status", "save_step_report"],
  "dev_mode": {
    "enabled": false,
    "skip_steps": [],
    "cutoff_step": null,
    "run_only_substeps": []
  },
  "steps": [
    {
      "id": "STEP_00",
      "name": "Intake & Normalization",
      "description": "Parse the conditions list, the evidence document list, and the optional loan scenario. Normalize categories and build an evaluation scenario summary.",
      "plan_file": "step_00_intake.md",
      "tools": ["parse_conditions", "parse_evidence", "build_eval_scenario"],
      "substeps": [
        {"id": "0.1", "name": "Parse conditions list", "tools": ["parse_conditions"]},
        {"id": "0.2", "name": "Parse evidence documents", "tools": ["parse_evidence"]},
        {"id": "0.3", "name": "Build evaluation scenario summary", "tools": ["build_eval_scenario"]},
        {"id": "0.4", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_01",
      "name": "Document Extraction & Classification",
      "description": "For each evidence document, confirm/derive its document type and a short summary so downstream matching and evaluation can reason over it (rack & stack).",
      "plan_file": "step_01_extraction.md",
      "tools": ["get_evidence_for_extraction", "store_evidence_classifications"],
      "substeps": [
        {"id": "1.1", "name": "Load evidence needing classification", "tools": ["get_evidence_for_extraction"]},
        {"id": "1.2", "name": "Store evidence classifications", "tools": ["store_evidence_classifications"]},
        {"id": "1.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_02",
      "name": "Candidate Matching (Cheap Filter)",
      "description": "Triage which evidence documents might satisfy which conditions. Run a deterministic category/keyword match, then LLM triage, producing a condition->evidence candidate map.",
      "plan_file": "step_02_candidate_matching.md",
      "tools": ["deterministic_candidate_match", "store_candidate_matches"],
      "substeps": [
        {"id": "2.1", "name": "Deterministic candidate match", "tools": ["deterministic_candidate_match"]},
        {"id": "2.2", "name": "Store LLM candidate matches", "tools": ["store_candidate_matches"]},
        {"id": "2.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_03",
      "name": "Income Condition Evaluation",
      "description": "Deep fulfillment evaluation for income-category conditions against their candidate evidence.",
      "plan_file": "step_03_income.md",
      "tools": ["get_conditions_to_evaluate", "store_income_evaluations"],
      "substeps": [
        {"id": "3.1", "name": "Load income conditions + candidate evidence", "tools": ["get_conditions_to_evaluate"]},
        {"id": "3.2", "name": "Store income evaluations", "tools": ["store_income_evaluations"]},
        {"id": "3.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_04",
      "name": "Assets & Reserves Condition Evaluation",
      "description": "Deep fulfillment evaluation for asset/reserves-category conditions against their candidate evidence.",
      "plan_file": "step_04_assets.md",
      "tools": ["get_conditions_to_evaluate", "store_assets_evaluations"],
      "substeps": [
        {"id": "4.1", "name": "Load asset conditions + candidate evidence", "tools": ["get_conditions_to_evaluate"]},
        {"id": "4.2", "name": "Store asset evaluations", "tools": ["store_assets_evaluations"]},
        {"id": "4.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_05",
      "name": "Credit Condition Evaluation",
      "description": "Deep fulfillment evaluation for credit-category conditions against their candidate evidence.",
      "plan_file": "step_05_credit.md",
      "tools": ["get_conditions_to_evaluate", "store_credit_evaluations"],
      "substeps": [
        {"id": "5.1", "name": "Load credit conditions + candidate evidence", "tools": ["get_conditions_to_evaluate"]},
        {"id": "5.2", "name": "Store credit evaluations", "tools": ["store_credit_evaluations"]},
        {"id": "5.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_06",
      "name": "Property & Appraisal Condition Evaluation",
      "description": "Deep fulfillment evaluation for property/appraisal/collateral-category conditions against their candidate evidence.",
      "plan_file": "step_06_property.md",
      "tools": ["get_conditions_to_evaluate", "store_property_evaluations"],
      "substeps": [
        {"id": "6.1", "name": "Load property conditions + candidate evidence", "tools": ["get_conditions_to_evaluate"]},
        {"id": "6.2", "name": "Store property evaluations", "tools": ["store_property_evaluations"]},
        {"id": "6.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_07",
      "name": "Title, Insurance, Compliance & Identity Evaluation",
      "description": "Deep fulfillment evaluation for title, insurance, compliance, identity, and other remaining-category conditions against their candidate evidence.",
      "plan_file": "step_07_title_compliance.md",
      "tools": ["get_conditions_to_evaluate", "store_title_compliance_evaluations"],
      "substeps": [
        {"id": "7.1", "name": "Load remaining conditions + candidate evidence", "tools": ["get_conditions_to_evaluate"]},
        {"id": "7.2", "name": "Store title/compliance evaluations", "tools": ["store_title_compliance_evaluations"]},
        {"id": "7.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    },
    {
      "id": "STEP_08",
      "name": "Aggregation & Human-in-the-Loop Packaging",
      "description": "Merge all per-condition evaluations, normalize verdicts, derive overall status, flag low-confidence/ambiguous items for human review, compute stats, and assemble the final output.",
      "plan_file": "step_08_aggregation.md",
      "tools": ["merge_evaluations", "generate_final_output"],
      "substeps": [
        {"id": "8.1", "name": "Merge & normalize all evaluations", "tools": ["merge_evaluations"]},
        {"id": "8.2", "name": "Generate final output", "tools": ["generate_final_output"]},
        {"id": "8.3", "name": "Save step report", "tools": ["save_step_report"]}
      ]
    }
  ]
}
