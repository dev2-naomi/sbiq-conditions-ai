# Anthropic API key for the LLM orchestrator
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model override (defaults to claude-opus-4-5)
ANTHROPIC_MODEL=claude-opus-4-5

# Optional dev-mode controls (skip/cutoff steps during local testing)
# DEV_MODE_ENABLED=true
# DEV_MODE_SKIP_STEPS=STEP_04,STEP_05
# DEV_MODE_CUTOFF_STEP=STEP_02
